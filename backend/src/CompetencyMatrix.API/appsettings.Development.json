{
  "Cors": {
    "AllowedOrigins": "http://localhost:5173;http://localhost:5175;http://localhost:3000"
  },
  "Jwt": {
    "Secret": "DEV_ONLY_PLACEHOLDER_DO_NOT_USE_IN_PRODUCTION_AT_LEAST_32_CHARS",
    "Issuer": "CompetencyMatrix",
    "Audience": "CompetencyMatrix",
    "ExpiryMinutes": "480"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
